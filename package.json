{
  "name": "collect-container-logs",
  "version": "3.0.0",
  "description": "Collect logs from all running docker containers.",
  "type": "module",
  "main": "src/main.js",
  "scripts": {
    "test": "node --test src/*.test.js",
    "check": "node --check src/*.js",
    "fix": "npm run lint -- --write",
    "lint": "npx prettier --check \"**/*.{js,yml,md}\"",
    "all": "npm run fix && npm run check && npm run lint && npm test"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "prettier": {
    "trailingComma": "all",
    "printWidth": 80,
    "tabWidth": 2,
    "semi": true,
    "singleQuote": true
  },
  "license": "Apache-2.0"
}
